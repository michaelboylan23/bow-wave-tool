{
  "name": "bow-wave-tool",
  "private": true,
  "version": "1.2.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder build --win portable"
  },
  "main": "electron/main.cjs",
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.21",
    "papaparse": "^5.5.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.7.0",
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.bowwave.analysis",
    "productName": "Bow Wave Analysis",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/main.cjs",
      "electron/preload.cjs"
    ],
    "asarUnpack": [
      "electron/preload.cjs"
    ],
    "win": {
      "target": "portable",
      "icon": "public/app_icon.ico",
      "forceCodeSigning": false
    },
    "electronDownload": {
      "cache": "C:\\Users\\Michael Boylan\\AppData\\Local\\electron-builder\\Cache"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tailwindcss": "^4.2.1",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  }
}
